# ---------------------------------------------------------------------------
# .env.example — Clínica Lichi
# Copiar como .env (desarrollo) o .env.production y completar los valores.
# NUNCA commitear archivos .env con datos reales.
# ---------------------------------------------------------------------------

# BASE DE DATOS
POSTGRES_DB=clinica_db
POSTGRES_USER=clinica
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
POSTGRES_HOST=db
POSTGRES_PORT=5432

# DJANGO
# Generar con: openssl rand -hex 50
SECRET_KEY=CAMBIAR_por-clave-de-50-caracteres-generada-con-openssl
DEBUG=False
ALLOWED_HOSTS=tu-dominio.duckdns.org
DJANGO_SETTINGS_MODULE=config.settings.production

# CORS y CSRF (deben coincidir con el dominio real)
CORS_ALLOWED_ORIGINS=https://tu-dominio.duckdns.org
CSRF_TRUSTED_ORIGINS=https://tu-dominio.duckdns.org

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# VITE
VITE_API_URL=/api

# EMAIL (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
SITE_URL=https://tu-dominio.duckdns.org

# ALMACENAMIENTO DE ARCHIVOS
STORAGE_BACKEND=local
# Para migrar a S3 descomentar:
# STORAGE_BACKEND=s3
# AWS_BUCKET_NAME=clinica-archivos
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
