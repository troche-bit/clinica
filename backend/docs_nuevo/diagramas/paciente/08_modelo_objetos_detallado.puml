@startuml 08_modelo_objetos_detallado

skinparam monochrome true
skinparam shadowing false
skinparam roundcorner 0
skinparam backgroundColor white
skinparam class {
  BackgroundColor #ffffff
  BorderColor #000000
  ArrowColor #000000
}

' ── Actores ──────────────────────────────────────────────────

class "Recepcionista" <<actor>> {
  + gestionar pacientes
  + visualizar historial
  + cancelar citas
}

class "Administrador" <<actor>> {
  + gestionar pacientes
  + eliminar pacientes
  + ver registros eliminados
}

' ── Boundaries ───────────────────────────────────────────────

class "PacientePage" <<boundary>> {
  -- Elementos UI --
  + txt_buscar: string
  + btn_nuevo: Button
  + btn_ver: Button
  + btn_editar: Button
  + btn_eliminar: Button
  + btn_listado_pdf: Button
  + btn_listado_excel: Button
  -- Comportamiento --
  + mostrar lista de pacientes
  + abrir modal_formulario
  + confirmar eliminación con ConfirmDialog
  + mostrar toast éxito/error
}

class "PacienteForm" <<boundary>> {
  -- Elementos UI --
  + modal_formulario: Modal
  + btn_guardar: Button
  + btn_cancelar: Button
  + btn_confirmar: Button
  -- Comportamiento --
  + modo: crear | editar | ver
  + gestionar resultado de búsqueda
  + invocar guardar en dos pasos (Persona → Paciente)
}

class "BuscadorPersona" <<boundary>> {
  -- Elementos UI --
  + txt_nro_documento: TextInput
  + btn_buscar_persona: Button
  -- Comportamiento --
  + disparar búsqueda al perder foco
  + mostrar badge: "Documento no encontrado" | "Persona encontrada" | "Ya es paciente"
  + resolver modo: crear_todo | agregar_paciente | ya_es_paciente
}

class "FormPersona" <<boundary>> {
  -- Elementos UI --
  + inp_razon_social: TextInput
  + inp_telefono: TextInput
  + inp_fecha_nacimiento: DateInput
  + sel_tipo_documento: Select
  + sel_ciudad: Select
  -- Comportamiento --
  + editable en modo crear_todo
  + solo lectura si persona ya existe
}

class "FormPaciente" <<boundary>> {
  -- Elementos UI --
  + sel_sexo: Select
  + sel_grupo_sanguineo: Select
  + txt_alergias: TextArea
  + sel_responsable: Select
  + tab_datos: Tab
  + tab_consultas: Tab
  + tab_documentos: Tab
  -- Comportamiento --
  + sexo obligatorio
  + responsable opcional
  + pestañas visibles solo en modo ver/editar
}

' ── Controls ─────────────────────────────────────────────────

class "PacienteViewSet" <<control>> {
  -- Configuración --
  + queryset: Paciente.activos (is_deleted=False)
  + search_fields: [persona__razon_social, persona__nro_documento]
  + permission_classes: tres niveles (lectura/escritura/admin)
  -- Acciones --
  + list()
  + create()
  + retrieve()
  + partial_update()
  + destroy()
  + eliminados()
  + perform_destroy(): verifica citas activas antes de delegar
}

class "PersonaViewSet" <<control>> {
  -- Configuración --
  + queryset: Persona.activos (is_deleted=False)
  + search_fields: [nro_documento, razon_social]
  -- Acciones --
  + create()
  + buscar(): GET ?nro_documento=X → {persona, paciente, es_paciente}
}

class "AgendaViewSet" <<control>> {
  -- Configuración --
  + queryset: Agenda.activos (is_deleted=False)
  -- Acciones --
  + asignar(): PATCH — asigna paciente, estado→OCUPADO
  + cambiar_estado(): PATCH — cambia estado del turno
}

' ── Entities ─────────────────────────────────────────────────

class "Paciente" <<entity>> {
  -- Campos de negocio --
  + id: AutoField
  + persona: FK → Persona
  + sexo: CharField [M/F]
  + grupo_sanguineo: CharField
  + alergias_conocidas: TextField
  + responsable: FK → PacienteResponsable (nullable)
  -- Campos BaseModel --
  + is_deleted: BooleanField = False
  + fecha_creacion: DateTimeField
  + fecha_modificacion: DateTimeField
  + fecha_eliminacion: DateTimeField (nullable)
  + id_usu_creator: FK → User
  + id_usu_modificator: FK → User
}

class "Persona" <<entity>> {
  -- Campos de negocio --
  + id: AutoField
  + nro_documento: CharField (único)
  + razon_social: CharField
  + tipo_documento: FK → TipoDocumento
  + ciudad: FK → Ciudad
  + telefono: CharField
  + fecha_nacimiento: DateField
  -- Campos BaseModel --
  + is_deleted: BooleanField = False
  + fecha_creacion: DateTimeField
  + fecha_modificacion: DateTimeField
}

class "Agenda" <<entity>> {
  -- Campos de negocio --
  + id: AutoField
  + paciente: FK → Paciente (nullable)
  + horario_prestador: FK → HorarioPrestador
  + estado: CharField [DISPONIBLE/OCUPADO/CANCELADO/REALIZADO/INACTIVO]
  -- Campos BaseModel --
  + is_deleted: BooleanField = False
  + fecha_creacion: DateTimeField
  + fecha_modificacion: DateTimeField
}

' ── Relaciones ───────────────────────────────────────────────

"Recepcionista" --> "PacientePage"
"Administrador" --> "PacientePage"

"PacientePage" --> "PacienteForm"
"PacienteForm" --> "BuscadorPersona"
"PacienteForm" --> "FormPersona"
"PacienteForm" --> "FormPaciente"

"PacientePage" --> "PacienteViewSet"
"PacienteForm" --> "PacienteViewSet"
"PacienteForm" --> "PersonaViewSet"
"BuscadorPersona" --> "PersonaViewSet"

"PacienteViewSet" --> "Paciente"
"PersonaViewSet" --> "Persona"
"AgendaViewSet" --> "Agenda"

"Paciente" --> "Persona"
"Paciente" --> "Agenda"

@enduml
