@startuml 07_modelo_objetos

skinparam monochrome true
skinparam shadowing false
skinparam roundcorner 0
skinparam backgroundColor white

skinparam class {
  BackgroundColor #ffffff
  BorderColor #000000
  ArrowColor #000000
}

class "Administrador" <<actor>> {
  + cargar horarios
  + agregar bloque horario
  + editar bloque horario
  + generar turnos
  + descargar reporte
}

class "Secretaria médico" <<actor>> {
  + ver horarios de su médico asignado
  + generar turnos para su médico asignado
}

class "HorarioPrestadorPage" <<boundary>> {
  + mostrar tabla de prestadores
  + mostrar pills de horarios
  + mostrar panel lateral (ver/editar)
  + mostrar panel Generar turnos
  + mostrar vista previa de turnos
  + mostrar resultado de generación
}

class "BloqueHorario" <<boundary>> {
  + mostrar formulario de bloque
  + agregar bloque vacío
  + editar bloque existente
  + calcular vista previa de slots
}

class "HorarioPrestadorViewSet" <<control>> {
  + list()
  + create()
  + update()
  + destroy()
  + eliminados()
  + generar()
  + reporte_horarios()
  + reporte_horarios_excel()
  + perform_destroy()
}

class "PersonaRRHHViewSet" <<control>> {
  + list()
}

class "AgendaViewSet" <<control>> {
  + bulk_create() via generar
}

class "HorarioPrestador" <<entity>> {
  + id
  + persona_rrhh: FK PersonaRRHH
  + dia_semana: FK DiaSemana
  + hora_desde
  + hora_hasta
  + intervalo
  + especialidades: M2M Especialidad
  + estado
  + excepcion
  + fecha_excepcion
  + is_deleted
  + id_usu_creator
  + id_usu_modificator
}

class "Agenda" <<entity>> {
  + id
  + horario_prestador: FK HorarioPrestador
  + fecha
  + hora_desde
  + estado
  + is_deleted
}

class "PersonaRRHH" <<entity>> {
  + id
  + persona: FK Persona
  + is_deleted
}

"Administrador" --> "HorarioPrestadorPage"
"Secretaria médico" --> "HorarioPrestadorPage"

"HorarioPrestadorPage" --> "BloqueHorario"

"HorarioPrestadorPage" --> "HorarioPrestadorViewSet"
"HorarioPrestadorPage" --> "PersonaRRHHViewSet"
"BloqueHorario" --> "HorarioPrestadorViewSet"
"HorarioPrestadorViewSet" --> "AgendaViewSet"

"HorarioPrestadorViewSet" --> "HorarioPrestador"
"AgendaViewSet" --> "Agenda"
"PersonaRRHHViewSet" --> "PersonaRRHH"

"HorarioPrestador" "0..*" --> "1" "PersonaRRHH" : persona_rrhh (FK)
"Agenda" "0..*" --> "1" "HorarioPrestador" : horario_prestador (FK)

@enduml
