@startuml 08_modelo_objetos_detallado

skinparam monochrome true
skinparam shadowing false
skinparam roundcorner 0
skinparam backgroundColor white

skinparam class {
  BackgroundColor #ffffff
  BorderColor #000000
  ArrowColor #000000
}

class "Recepcionista" <<actor>>
class "Medico" <<actor>>
class "Sistema Cron" <<actor>>

class "RecordatoriosPage" <<boundary>> {
  +sel_periodo
  +sel_medico
  +sel_estado
  +txt_buscar
  +tbl_recordatorios
  +panel_detalle
  +lbl_paciente
  +lbl_proxima_cita
  +lbl_dias_restantes
  +badge_urgencia
  +btn_recordatorio
  +btn_confirmacion
  +btn_indicaciones
  +historial_expandido
  --
  +verProximasCitas()
  +abrirDetalle()
  +expandirHistorial()
}

class "ModalNotificacion" <<boundary>> {
  +sel_canal
  +txt_destinatario
  +txt_mensaje
  +btn_enviar
  +btn_cancelar
  --
  +confirmarEnvio()
  +cancelar()
}

class "RecordatorioViewSet" <<control>> {
  +filtros : [dias, medico, estado, busqueda]
  --
  +get_permissions()
  +proximas_citas()
  +stats()
  +notificar()
}

class "ConsultaViewSet" <<control>> {
  +queryset : Consulta.activos
  --
  +partial_update()
  +finalizar()
}

class "ServicioNotificacion" <<control>> {
  +resend_api_key : settings
  --
  +build_contexto()
  +renderizar_plantilla()
  +enviar_email()
  +registrar_auditoria()
}

class "CronRecordatorios" <<control>> {
  +horas_anticipacion : config
  --
  +handle()
  +proxima_cita_objetivo()
  +deduplicar()
  +enviar_automatico()
}

class "Consulta" <<entity>> {
  +id : AutoField
  +proxima_cita : DateField
  +estado : CharField
  +diagnostico : TextField
  +indicaciones : TextField
  +is_deleted : BooleanField
  +fecha_creacion : DateTimeField
}

class "Notificacion" <<entity>> {
  +id : AutoField
  +paciente : ForeignKey
  +consulta : ForeignKey
  +tipo : CharField
  +canal : CharField
  +estado : CharField
  +destinatario : CharField
  +mensaje : TextField
  +fecha_envio : DateTimeField
  +id_usu_creator : ForeignKey
  +is_deleted : BooleanField
}

class "ConfiguracionNotificacion" <<entity>> {
  +habilitado : BooleanField
  +auto_recordatorio : BooleanField
  +horas_anticipacion : IntegerField
  +horas_anticipacion_2 : IntegerField
  +email_remitente : CharField
}

class "PlantillaNotificacion" <<entity>> {
  +tipo : CharField
  +asunto : CharField
  +cuerpo : TextField
  +activa : BooleanField
  +is_deleted : BooleanField
}

Recepcionista  --> RecordatoriosPage
Medico         --> RecordatoriosPage
"Sistema Cron" --> CronRecordatorios

RecordatoriosPage --> RecordatorioViewSet
RecordatoriosPage --> ModalNotificacion
ModalNotificacion --> RecordatorioViewSet
CronRecordatorios --> ServicioNotificacion

RecordatorioViewSet --> Consulta
RecordatorioViewSet --> Notificacion
ServicioNotificacion --> Notificacion
ServicioNotificacion --> ConfiguracionNotificacion
ServicioNotificacion --> PlantillaNotificacion
ConsultaViewSet     --> Consulta

Consulta "1" --> "0..*" Notificacion : notificaciones

@enduml
