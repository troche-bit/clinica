@startuml 07_modelo_objetos

skinparam monochrome true
skinparam shadowing false
skinparam roundcorner 0
skinparam backgroundColor white

skinparam class {
  BackgroundColor #ffffff
  BorderColor #000000
  ArrowColor #000000
}

class "Recepcionista" <<actor>>
class "Medico" <<actor>>
class "Sistema Cron" <<actor>>

class "RecordatoriosPage" <<boundary>> {
  +seleccionado
  +periodo
  +expandedRow
  --
  +verProximasCitas()
  +abrirDetalle()
  +enviarNotificacion()
  +verHistorial()
}

class "ModalNotificacion" <<boundary>> {
  +canal
  +destinatario
  +mensaje
  --
  +confirmarEnvio()
  +cancelar()
}

class "RecordatorioViewSet" <<control>> {
  +get_permissions()
  --
  +proximas_citas()
  +stats()
  +notificar()
}

class "ConsultaViewSet" <<control>> {
  --
  +partial_update()
  +finalizar()
}

class "ServicioNotificacion" <<control>> {
  --
  +build_contexto()
  +renderizar()
  +enviar_email()
}

class "CronRecordatorios" <<control>> {
  --
  +handle()
  +deduplicar()
}

class "Consulta" <<entity>> {
  +id : AutoField
  +proxima_cita : DateField
  +estado : CharField
  +is_deleted : BooleanField
}

class "Notificacion" <<entity>> {
  +id : AutoField
  +paciente : ForeignKey
  +consulta : ForeignKey
  +tipo : CharField
  +canal : CharField
  +estado : CharField
  +destinatario : CharField
  +fecha_envio : DateTimeField
  +id_usu_creator : ForeignKey
  +is_deleted : BooleanField
}

class "ConfiguracionNotificacion" <<entity>> {
  +habilitado : BooleanField
  +auto_recordatorio : BooleanField
  +horas_anticipacion : IntegerField
  +email_remitente : CharField
}

class "PlantillaNotificacion" <<entity>> {
  +tipo : CharField
  +asunto : CharField
  +cuerpo : TextField
  +activa : BooleanField
}

Recepcionista  --> RecordatoriosPage
Medico         --> RecordatoriosPage
"Sistema Cron" --> CronRecordatorios

RecordatoriosPage --> RecordatorioViewSet
RecordatoriosPage --> ModalNotificacion
ModalNotificacion --> RecordatorioViewSet
CronRecordatorios --> ServicioNotificacion

RecordatorioViewSet --> Consulta
RecordatorioViewSet --> Notificacion
ServicioNotificacion --> Notificacion
ServicioNotificacion --> ConfiguracionNotificacion
ServicioNotificacion --> PlantillaNotificacion
ConsultaViewSet     --> Consulta

Consulta "1" --> "0..*" Notificacion : notificaciones

@enduml
